   "source": [
    "def kurtosis(x):\n",
    "    n = len(x)\n",
    "    mean_x = sum(x) / n\n",
    "    return (\n",
    "        sum((xi - mean_x) ** 4 for xi in x)\n",
    "        / n\n",
    "        / (sum((xi - mean_x) ** 2 for xi in x) / n) ** 2\n",
    "    )"
   ]
  }
 ],
